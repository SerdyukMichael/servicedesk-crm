# ─────────────────────────────────────────────
# Настройка diff для бинарных форматов документов
# ─────────────────────────────────────────────

# Word: текстовый diff через scripts/docx2txt.py
*.docx diff=word

# Excel и PDF — помечаем как бинарники (без diff)
*.xlsx binary
*.xls  binary
*.pdf  binary

# Zip-архивы — бинарники
*.zip  binary
