# ================================================================
# ServiceDesk CRM — Backend environment variables
# Скопировать в .env и заполнить реальными значениями:
#   cp .env.example .env
# ================================================================

# ----------------------------------------------------------------
# База данных MySQL
# ----------------------------------------------------------------
# Для запуска внутри Docker Compose (хост = имя сервиса):
DATABASE_URL=mysql+pymysql://sduser:sdpass@mysql:3306/servicedesk
# Для локального запуска без Docker (хост = localhost):
# DATABASE_URL=mysql+pymysql://sduser:sdpass@localhost:3306/servicedesk

MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=servicedesk
MYSQL_USER=sduser
MYSQL_PASSWORD=sdpass

# ----------------------------------------------------------------
# JWT-аутентификация (ADR-006)
# Сгенерировать SECRET_KEY:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ----------------------------------------------------------------
SECRET_KEY=change-me-generate-with-secrets-token-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ----------------------------------------------------------------
# Redis / Celery (ADR-002)
# Для Docker Compose:
# ----------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
# Для локального запуска:
# REDIS_URL=redis://localhost:6379/0

# ----------------------------------------------------------------
# Email-уведомления (ADR-003)
# smtplib — stdlib Python, без зависимостей
# ----------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ----------------------------------------------------------------
# Telegram Bot (ADR-003)
# Получить токен: https://t.me/BotFather → /newbot
# Если пустой — канал Telegram пропускается без ошибки
# ----------------------------------------------------------------
TELEGRAM_BOT_TOKEN=

# ----------------------------------------------------------------
# Лимиты файлов (ADR-001)
# Файлы хранятся в MySQL BLOB. Проверяется в FileService.
# MySQL max_allowed_packet настроен в docker-compose.yml: 25M
# ----------------------------------------------------------------
MAX_FILE_SIZE_MB=20
